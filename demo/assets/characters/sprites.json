        "attack": { "rowBase": 12, "rowFromDir": true, "frames": 6, "fps": 12, "skipFrame0": false }
      },
      "previewFrame": { "row": 8, "col": 0 }
    },
    "mage": {
      "sheet": "assets/characters/lpc_mage.png",
      "anims": {
        "idle":   { "rowBase": 8,  "rowFromDir": true, "frames": 1, "fps": 1,  "skipFrame0": false },
        "walk":   { "rowBase": 8,  "rowFromDir": true, "frames": 8, "fps": 10, "skipFrame0": true  },
        "attack": { "rowBase": 0,  "rowFromDir": true, "frames": 7, "fps": 12, "skipFrame0": false }
      },
      "previewFrame": { "row": 8, "col": 0 }
    },
    "scout": {
      "sheet": "assets/characters/lpc_scout.png",
      "anims": {
        "idle":   { "rowBase": 8,  "rowFromDir": true, "frames": 1, "fps": 1,  "skipFrame0": false },
        "walk":   { "rowBase": 8,  "rowFromDir": true, "frames": 8, "fps": 10, "skipFrame0": true  },
