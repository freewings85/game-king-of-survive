{
  "_spec": "LPC standard. 64x64 frames, 13 cols x 21 rows = 832x1344. Direction order: U/L/D/R.",
  "_locked_by": "GameDesigner v1 doc 2026-04-11",
  "frameW": 64,
  "frameH": 64,
  "sheetCols": 13,
