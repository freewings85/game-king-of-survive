  "facingAngleMapping": {
    "_comment": "facingAngle in radians, 0=right, +pi/2=down (canvas convention). Map to LPC dir row offset.",
    "right": { "rowOffset": 3, "angleRange": [-0.785, 0.785] },
    "down":  { "rowOffset": 2, "angleRange": [0.785, 2.356] },
    "left":  { "rowOffset": 1, "angleRange": [2.356, 3.1416, -3.1416, -2.356] },
    "up":    { "rowOffset": 0, "angleRange": [-2.356, -0.785] }
  }
